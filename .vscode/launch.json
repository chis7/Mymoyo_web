{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: MyMoyo (Postgres)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/mymoyo/manage.py",
            "cwd": "${workspaceFolder}/mymoyo",
            "args": [
                "runserver",
                "127.0.0.1:7000"
            ],
            "django": true,
            "justMyCode": true,
            "subProcess": true,
            "console": "integratedTerminal"
        }
    ]
}
